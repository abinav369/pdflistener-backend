# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME="PDF Listener API"
DEBUG=false

# ── Security ───────────────────────────────────────────────────────────────────
# CHANGE THIS to a long random string in production!
SECRET_KEY="super-secret-key-change-me"
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="sqlite:///./pdflistener.db"
# For PostgreSQL: DATABASE_URL="postgresql://user:password@localhost/pdflistener"

# ── Storage ────────────────────────────────────────────────────────────────────
UPLOAD_DIR="uploads"
AUDIO_OUTPUT_DIR="audio_output"
MAX_UPLOAD_SIZE_MB=50

# ── TTS Engine ─────────────────────────────────────────────────────────────────
# Options: "gtts" (free, needs internet) | "openai" (premium)
TTS_ENGINE="gtts"
OPENAI_API_KEY=""

# ── CORS ───────────────────────────────────────────────────────────────────────
# In production, replace * with your Flutter app's domain / IP
ALLOWED_ORIGINS=["*"]
